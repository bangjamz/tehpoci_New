rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'OWNER';
    }
    function isCashier() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'CASHIER';
    }
    function isActiveUser() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_active == true;
    }

    // Config (authorized owners, app settings)
    match /config/{docId} {
      // Siapa saja yang authenticated bisa baca — dibutuhkan saat login untuk cek email
      allow read: if request.auth != null;
      // Hanya Owner yang bisa ubah
      allow write: if isOwner();
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isOwner();
      // Self-register (Owner pertama kali login) ATAU Owner membuat akun kasir
      allow create: if (request.auth.uid == userId && request.resource.data.uid == request.auth.uid)
                    || (isOwner() && request.resource.data.role == 'CASHIER' && request.resource.data.uid == userId);
      allow update, delete: if isOwner();
    }

    match /products/{productId} {
      allow read: if isActiveUser();
      allow write: if isOwner();
    }

    match /stores/{storeId} {
      allow read: if isActiveUser();
      allow write: if isOwner() || (request.auth != null && !exists(/databases/$(database)/documents/stores/$(storeId)));

      match /shifts/{shiftId} {
        allow read: if isActiveUser();
        allow create: if isCashier() && isActiveUser();
        allow update: if (isCashier() && isActiveUser()) || isOwner();
      }

      match /transactions/{txId} {
        allow read: if isActiveUser();
        allow create: if isCashier() && isActiveUser();
        allow update, delete: if isOwner();
      }
    }
  }
}
