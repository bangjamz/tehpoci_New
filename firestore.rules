rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'OWNER';
    }
    function isCashier() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'CASHIER';
    }
    function isActiveUser() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_active == true;
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isOwner();
      // Allow a user to create ONLY their own document, ONLY if they don't have one yet
      // Role validation: only OWNER or CASHIER allowed
      allow create: if request.auth.uid == userId
                    && request.resource.data.role in ['OWNER', 'CASHIER']
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner();
    }

    match /products/{productId} {
      allow read: if isActiveUser();
      allow write: if isOwner();
    }

    match /stores/{storeId} {
      allow read: if isActiveUser();
      // Allow Owner to create store, and also allow bootstrap (first setup)
      allow write: if isOwner() || (request.auth != null && !exists(/databases/$(database)/documents/stores/$(storeId)));

      match /shifts/{shiftId} {
        allow read: if isActiveUser();
        allow create: if isCashier() && isActiveUser();
        allow update: if (isCashier() && isActiveUser()) || isOwner();
      }

      match /transactions/{txId} {
        allow read: if isActiveUser();
        allow create: if isCashier() && isActiveUser();
        allow update, delete: if isOwner();
      }
    }
  }
}
