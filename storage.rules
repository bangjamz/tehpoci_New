rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      allow read: if request.auth != null;
      // Izinkan upload untuk semua user yang sudah login.
      // Keamanan upload dikendalikan di sisi app (hanya Owner yang punya UI upload).
      // Cross-service firestore.get() dihindari karena tidak reliable di semua konfigurasi.
      allow write: if request.auth != null;
    }
  }
}
